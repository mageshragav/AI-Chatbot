# Database
DATABASE_URL=postgres://user:password@localhost:5432/ai_chatbot

# AI Configuration (Required)
AI_API_KEY=your-openai-api-key-here
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=1000
AI_TIMEOUT=30

# Vector Store Configuration
CHROMA_PERSIST_DIR=./chroma_data
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_SEARCH_TOP_K=5

# API Configuration
API_TITLE=AI Agent - Django ORM Query Generator
API_VERSION=1.0.0
API_DESCRIPTION=Convert natural language to Django ORM queries
API_RATE_LIMIT=100
API_TIMEOUT=30

# Cache Configuration (Optional - Redis)
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL=3600
# CACHE_ENABLED=false

# Security
ALLOWED_ORIGINS=*
API_KEY_PREFIX=sk_proj_

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Agent Configuration
AGENT_TOOL_CALL_LIMIT=7
AGENT_MODEL_CALL_LIMIT=7
